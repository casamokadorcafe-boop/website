---
/**
 * Menu — three categories with classic Italian leader-line rows.
 *  - Section opens with the "Three origins, one cup" treatment.
 *  - Sticky tab strip below the section header (horizontal-scrollable on mobile).
 *  - Active tab highlights via IntersectionObserver as the user scrolls.
 *  - Two-column item grid from md+.
 */
import { MENU, formatPrice } from '../data/menu';
---

<section id="menu" class="mk-menu" aria-label="Menu">

  <!-- Section header -->
  <header class="mk-menu__header mk-container">
    <p class="mk-eyebrow mk-flag mk-reveal">The Menu</p>
    <h2 class="mk-menu__title font-display mk-reveal" style="--i:1">
      <span class="mk-gold-metallic">Three origins,</span>
      <span class="mk-menu__title-it">one cup.</span>
    </h2>

    <div class="mk-menu__origins mk-reveal" style="--i:2" aria-label="Three coffee origins">
      <span class="mk-menu__origin">
        <span class="mk-menu__origin-dot mk-menu__origin-dot--green" aria-hidden="true"></span>
        Brazil
      </span>
      <span class="mk-menu__origin-sep" aria-hidden="true">·</span>
      <span class="mk-menu__origin">
        <span class="mk-menu__origin-dot mk-menu__origin-dot--cream" aria-hidden="true"></span>
        Colombia
      </span>
      <span class="mk-menu__origin-sep" aria-hidden="true">·</span>
      <span class="mk-menu__origin">
        <span class="mk-menu__origin-dot mk-menu__origin-dot--red" aria-hidden="true"></span>
        Costa Rica
      </span>
    </div>

    <p class="mk-menu__lede mk-reveal" style="--i:3">
      Roasted by Mokador in Italy. Pulled at the bar in Pafos.
    </p>
  </header>

  <!-- Sticky tab strip -->
  <div class="mk-menu__tabs-wrap">
    <div class="mk-menu__tabs mk-no-scrollbar mk-container" role="tablist" aria-label="Menu categories">
      {MENU.map((cat) => (
        <a href={`#cat-${cat.id}`} class="mk-menu__tab" data-target={`cat-${cat.id}`} role="tab" aria-selected="false">
          <span>{cat.title}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Category sections -->
  <div class="mk-menu__sections mk-container">
    {MENU.map((cat, idx) => (
      <section id={`cat-${cat.id}`} class="mk-menu__category mk-reveal" aria-labelledby={`heading-${cat.id}`}>

        <header class="mk-menu__cat-head">
          <span class="mk-eyebrow">{String(idx + 1).padStart(2, '0')}</span>
          <h3 id={`heading-${cat.id}`} class="mk-menu__cat-title">
            <span class="mk-gold-metallic">{cat.title}</span>
          </h3>
          <p class="mk-menu__cat-caption">{cat.caption}</p>
          <span class="mk-rule" aria-hidden="true"></span>
        </header>

        <ul class={`mk-menu__items${cat.showPhotos ? ' mk-menu__items--photos' : ''}`}>
          {cat.items.map((item) => (
            <li>
              {cat.showPhotos && (
                <div class="mk-menu__photo">
                  {item.photo
                    ? <img src={item.photo} alt={item.name} loading="lazy" decoding="async" />
                    : <span class="mk-menu__photo-empty" aria-hidden="true">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="5" width="18" height="14" rx="2"/>
                          <circle cx="12" cy="12" r="3.5"/>
                          <path d="M8 5l1.5-2h5L16 5"/>
                        </svg>
                      </span>
                  }
                </div>
              )}
              <div class="mk-row">
                <span class="mk-row__name">{item.name}</span>
                <span class="mk-row__leader" aria-hidden="true"></span>
                <span class="mk-row__price">{formatPrice(item.price)}</span>
              </div>
            </li>
          ))}
        </ul>

      </section>
    ))}
  </div>

</section>

<style>
  .mk-menu {
    padding-block: clamp(5rem, 12vh, 9rem);
    position: relative;
  }

  /* Header */
  .mk-menu__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .mk-menu__title {
    font-size: clamp(2rem, 5vw, 3.75rem);
    line-height: 1.1;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4em;
  }
  .mk-menu__title-it {
    font-style: italic;
    color: var(--color-mk-cream);
  }
  .mk-menu__lede {
    color: var(--color-mk-cream-mute);
    max-width: 44ch;
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: italic;
    font-size: 15px;
    letter-spacing: 0.005em;
  }

  /* Origins line */
  .mk-menu__origins {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.875rem;
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 12px;
    color: var(--color-mk-cream);
    margin-top: 0.25rem;
  }
  .mk-menu__origin {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mk-menu__origin-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
  }
  .mk-menu__origin-dot--green { background: var(--color-mk-it-green); }
  .mk-menu__origin-dot--cream { background: var(--color-mk-cream); }
  .mk-menu__origin-dot--red   { background: var(--color-mk-it-red); }
  .mk-menu__origin-sep {
    color: var(--color-mk-gold);
    opacity: 0.7;
  }

  /* Sticky tabs */
  .mk-menu__tabs-wrap {
    position: sticky;
    top: 64px; /* below the nav */
    z-index: 30;
    background: color-mix(in oklab, var(--color-mk-black) 86%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-block: 1px solid color-mix(in oklab, var(--color-mk-gold) 14%, transparent);
    margin-bottom: clamp(2rem, 5vh, 3.5rem);
  }
  .mk-menu__tabs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    overflow-x: auto;
    overflow-y: hidden;
    padding-block: 0.625rem;
    scroll-behavior: smooth;
  }
  .mk-menu__tab {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    padding: 0.625rem 1rem;
    min-height: 44px;
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: clamp(13px, 1vw, 14px);
    color: var(--color-mk-cream-mute);
    border: 1px solid transparent;
    position: relative;
    transition: color 240ms var(--ease-mk), border-color 240ms var(--ease-mk);
    white-space: nowrap;
  }
  .mk-menu__tab::after {
    content: "";
    position: absolute;
    left: 1rem;
    right: 1rem;
    bottom: 0.375rem;
    height: 1px;
    background: var(--color-mk-gold);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 320ms var(--ease-mk);
  }
  .mk-menu__tab:hover { color: var(--color-mk-cream); }
  .mk-menu__tab[aria-selected="true"] {
    color: var(--color-mk-gold);
  }
  .mk-menu__tab[aria-selected="true"]::after {
    transform: scaleX(1);
  }

  /* Categories */
  .mk-menu__sections {
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 8vh, 5.5rem);
    /* Offset scroll-to so sticky tab strip doesn't cover headings */
    scroll-padding-top: 140px;
  }
  .mk-menu__category {
    scroll-margin-top: 130px;
  }
  .mk-menu__cat-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: clamp(1.5rem, 4vh, 2.25rem);
  }
  .mk-menu__cat-title {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.2;
    letter-spacing: 0.005em;
    margin: 0;
    color: var(--color-mk-cream);
  }
  .mk-menu__cat-caption {
    font-family: var(--font-sans);
    font-weight: 400;
    font-style: italic;
    color: var(--color-mk-cream-mute);
    margin: 0 0 0.875rem 0;
    font-size: 14px;
    letter-spacing: 0.005em;
  }

  .mk-menu__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .mk-menu__items li {
    border-bottom: 1px solid color-mix(in oklab, var(--color-mk-cream-dim) 22%, transparent);
  }
  .mk-menu__items li:first-child {
    border-top: 1px solid color-mix(in oklab, var(--color-mk-cream-dim) 22%, transparent);
  }
  @media (min-width: 768px) {
    .mk-menu__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: clamp(2rem, 5vw, 4rem);
    }
  }

  /* Photo slot — Pastries & Toast categories */
  .mk-menu__items--photos li {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-block: 0.75rem;
  }
  .mk-menu__items--photos .mk-row {
    flex: 1;
    min-width: 0;
  }
  .mk-menu__photo {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-mk-gold) 18%, transparent);
    background: color-mix(in oklab, var(--color-mk-black-soft) 80%, transparent);
  }
  .mk-menu__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mk-menu__photo-empty {
    display: flex;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
    color: color-mix(in oklab, var(--color-mk-gold) 30%, transparent);
  }
  .mk-menu__photo-empty svg {
    width: 28px;
    height: 28px;
  }
</style>

<script>
  // Active tab highlight via IntersectionObserver on each category
  const tabs = document.querySelectorAll<HTMLAnchorElement>('.mk-menu__tab');
  const cats = document.querySelectorAll<HTMLElement>('.mk-menu__category');
  const tabsStrip = document.querySelector<HTMLElement>('.mk-menu__tabs');

  if (tabs.length && cats.length) {
    const setActive = (id: string) => {
      tabs.forEach((t) => {
        const isActive = t.dataset.target === id;
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
        if (isActive && tabsStrip) {
          // Scroll the active tab into view inside the horizontal strip
          const tabRect = t.getBoundingClientRect();
          const stripRect = tabsStrip.getBoundingClientRect();
          if (tabRect.left < stripRect.left + 16 || tabRect.right > stripRect.right - 16) {
            t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
          }
        }
      });
    };

    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          // Pick the topmost intersecting category
          let topmost: IntersectionObserverEntry | null = null;
          for (const e of entries) {
            if (e.isIntersecting) {
              if (!topmost || e.boundingClientRect.top < topmost.boundingClientRect.top) {
                topmost = e;
              }
            }
          }
          if (topmost) setActive(topmost.target.id);
        },
        { rootMargin: '-140px 0px -60% 0px', threshold: 0 }
      );
      cats.forEach((c) => io.observe(c));
    }

    // Smooth scroll handlers (also disable default native anchor offset misalignment)
    tabs.forEach((tab) => {
      tab.addEventListener('click', (e) => {
        const target = tab.dataset.target;
        if (!target) return;
        const el = document.getElementById(target);
        if (!el) return;
        e.preventDefault();
        const top = el.getBoundingClientRect().top + window.scrollY - 130;
        window.scrollTo({ top, behavior: 'smooth' });
        setActive(target);
      });
    });
  }
</script>
