---
/**
 * Contact — two-column on desktop, stacked on mobile.
 *  - Info card (address, phone, hours, social) on the left.
 *  - Google Maps embed on the right.
 *  - All unknown fields are clearly marked with TODO + visually muted.
 */

// TODO: replace these with confirmed details
const ADDRESS = {
  street: 'Ayiou Kendea, Paphos 8046',
  city: 'Pafos',
  country: 'Cyprus',
};
const PHONE = '+357 97 416 416';
const HOURS = [
  { day: 'Monday – Sunday', value: '7:00 - 22:00' },     // TODO
];
const SOCIALS = [
  { label: 'Instagram', href: 'https://www.instagram.com/casamokador_?igsh=a2RtY2g5MzQxejl0', icon: 'instagram' },
{ label: 'TikTok',    href: 'https://www.tiktok.com/@casamokador?_r=1&_t=ZN-97HcQWjo3ss', icon: 'tiktok' },
];

const MAP_LAT = 34.776811;
const MAP_LON = 32.421137;
const mapSrc = `https://maps.google.com/maps?q=${MAP_LAT},${MAP_LON}&z=17&output=embed`;
const mapLink = `https://www.google.com/maps/place/Casa+Mokador/@${MAP_LAT},${MAP_LON},17z`;
---

<section id="contact" class="mk-contact" aria-label="Contact">

  <header class="mk-contact__header mk-container">
    <p class="mk-eyebrow mk-flag mk-reveal">Visit</p>
    <h2 class="mk-contact__title font-display mk-reveal" style="--i:1">
      <span class="mk-gold-metallic">Find us</span>
      <span class="mk-contact__title-it">in Pafos.</span>
    </h2>
  </header>

  <div class="mk-contact__grid mk-container">

    <!-- Info card -->
    <div class="mk-contact__info mk-reveal" style="--i:2">

      <div class="mk-contact__row">
        <span class="mk-contact__icon" aria-hidden="true">
          <!-- Pin -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 21s-7-6.5-7-12a7 7 0 1 1 14 0c0 5.5-7 12-7 12z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
        </span>
        <div>
          <span class="mk-contact__label">Address</span>
          <address class="mk-contact__value">
            {ADDRESS.street}<br/>
            {ADDRESS.city}, {ADDRESS.country}
          </address>
        </div>
      </div>

      <div class="mk-contact__row">
        <span class="mk-contact__icon" aria-hidden="true">
          <!-- Phone -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.86 19.86 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.86 19.86 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
        </span>
        <div>
          <span class="mk-contact__label">Phone</span>
          <a class="mk-contact__value mk-contact__link" href={`tel:${PHONE.replace(/[^+\d]/g, '')}`}>
            {PHONE}
          </a>
        </div>
      </div>

      <div class="mk-contact__row">
        <span class="mk-contact__icon" aria-hidden="true">
          <!-- Clock -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 2"/>
          </svg>
        </span>
        <div>
          <span class="mk-contact__label">Hours</span>
          <dl class="mk-contact__hours">
            {HOURS.map((h) => (
              <div class="mk-contact__hours-row">
                <dt>{h.day}</dt>
                <dd>{h.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>

      <div class="mk-contact__row">
        <span class="mk-contact__icon" aria-hidden="true">
          <!-- Link -->
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 14a5 5 0 0 0 7 0l3-3a5 5 0 1 0-7-7l-1 1"/>
            <path d="M14 10a5 5 0 0 0-7 0l-3 3a5 5 0 1 0 7 7l1-1"/>
          </svg>
        </span>
        <div>
          <span class="mk-contact__label">Social</span>
          <ul class="mk-contact__socials">
            {SOCIALS.map((s) => (
              <li>
                <a href={s.href} rel="noopener noreferrer me" target="_blank" aria-label={s.label}>
                  {s.icon === 'instagram' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <rect x="3" y="3" width="18" height="18" rx="5"/>
                      <circle cx="12" cy="12" r="4"/>
                      <circle cx="17.5" cy="6.5" r="0.9" fill="currentColor"/>
                    </svg>
                  )}
{s.icon === 'tiktok' && (
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5"/>
                      <path d="M14 4c0 2 1.5 4 4 4"/>
                    </svg>
                  )}
                  <span>{s.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

    </div>

    <!-- Map -->
    <div class="mk-contact__map mk-reveal" style="--i:3">
      <div class="mk-contact__map-frame">
        <iframe
          src={mapSrc}
          title="Map showing Casa Mokador location in Pafos, Cyprus"
          loading="lazy"
          referrerpolicy="no-referrer"
          allowfullscreen
          aria-label="Map of Casa Mokador in Pafos"
        ></iframe>
      </div>
      <a class="mk-contact__map-link" href={mapLink} rel="noopener noreferrer" target="_blank">
        Open in Google Maps
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M7 17 17 7"/>
          <path d="M9 7h8v8"/>
        </svg>
      </a>
    </div>

  </div>

</section>

<style>
  .mk-contact {
    padding-block: clamp(5rem, 12vh, 9rem);
    position: relative;
  }

  .mk-contact__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .mk-contact__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.1;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.4em;
  }
  .mk-contact__title-it {
    font-style: italic;
    color: var(--color-mk-cream);
  }

  .mk-contact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vh, 3rem);
    align-items: stretch;
  }
  @media (min-width: 1024px) {
    .mk-contact__grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: clamp(2rem, 4vw, 4rem);
    }
  }

  /* Info card */
  .mk-contact__info {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vh, 2rem);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    border: 1px solid color-mix(in oklab, var(--color-mk-gold) 18%, transparent);
    background: color-mix(in oklab, var(--color-mk-black-soft) 60%, transparent);
  }
  .mk-contact__row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: start;
  }
  .mk-contact__icon {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-mk-gold);
    border: 1px solid color-mix(in oklab, var(--color-mk-gold) 30%, transparent);
    flex-shrink: 0;
  }
  .mk-contact__label {
    display: block;
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 11px;
    color: var(--color-mk-cream-mute);
    margin-bottom: 0.5rem;
  }
  /* Address body (default value). Phone overrides via .mk-contact__link. */
  .mk-contact__value {
    font-family: var(--font-sans);
    font-weight: 400;
    font-size: 16px;
    color: var(--color-mk-cream);
    font-style: normal;
    line-height: 1.5;
    letter-spacing: 0;
  }
  /* Phone number — larger, semibold. */
  .mk-contact__link.mk-contact__value {
    font-weight: 500;
    font-size: 18px;
    letter-spacing: 0.005em;
    transition: color 200ms var(--ease-mk);
  }
  .mk-contact__link:hover { color: var(--color-mk-gold-light); }

  .mk-contact__hours {
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.25rem;
  }
  .mk-contact__hours-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: baseline;
    padding-block: 0.375rem;
    border-bottom: 1px dotted rgba(184, 174, 153, 0.35);
  }
  .mk-contact__hours-row:last-child { border-bottom: none; }
  .mk-contact__hours-row dt {
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-mk-cream);
    font-size: 15px;
    letter-spacing: 0;
  }
  .mk-contact__hours-row dd {
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-mk-cream-mute);
    font-variant-numeric: tabular-nums;
    font-size: 15px;
    letter-spacing: 0;
    margin: 0;
  }

  .mk-contact__socials {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .mk-contact__socials a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    min-height: 44px;
    padding: 0.5rem 0.875rem;
    border: 1px solid color-mix(in oklab, var(--color-mk-gold) 20%, transparent);
    color: var(--color-mk-cream);
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 12px;
    transition: all 200ms var(--ease-mk);
  }
  .mk-contact__socials a:hover {
    color: var(--color-mk-gold-light);
    border-color: var(--color-mk-gold-light);
  }

  /* Map */
  .mk-contact__map {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .mk-contact__map-frame {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    border: 1px solid color-mix(in oklab, var(--color-mk-gold) 18%, transparent);
    overflow: hidden;
    background: var(--color-mk-black-soft);
  }
  .mk-contact__map-frame iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .mk-contact__map-link {
    display: inline-flex;
    align-self: flex-end;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 11px;
    color: var(--color-mk-cream-mute);
    padding: 0.5rem 0.25rem;
    transition: color 200ms var(--ease-mk);
  }
  .mk-contact__map-link:hover { color: var(--color-mk-gold-light); }
  @media (min-width: 1024px) {
    .mk-contact__map-frame {
      aspect-ratio: auto;
      height: 100%;
      min-height: 460px;
    }
  }
</style>
