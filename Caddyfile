# Casa Mokador — Caddy static server config.
#
# Listens on $PORT (provided by Railway; defaults to 8080 locally).
# Serves /srv/dist with sensible cache headers and compression.

{
	# Don't bind to admin port; Railway gives one inbound port.
	admin off
	# Keep logs slim.
	log {
		output stdout
		format console
		level INFO
	}
}

:{$PORT:8080} {
	root * /srv/dist
	encode zstd gzip

	# Long-lived cache for fingerprinted assets emitted by Astro.
	@immutable {
		path /_astro/* /fonts/*
	}
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	# Short cache for everything else (HTML, public/ assets that may change).
	@html {
		path *.html / /index.html
	}
	header @html Cache-Control "public, max-age=0, must-revalidate"
	header /robots.txt Cache-Control "public, max-age=3600"
	header /sitemap*.xml Cache-Control "public, max-age=3600"

	# Sensible security headers.
	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "interest-cohort=()"
		# OpenStreetMap embed runs in an iframe, so don't set X-Frame-Options here.
	}

	# Try the request path, then index.html, else 404.
	try_files {path} {path}/ /index.html

	file_server {
		precompressed gzip
	}
}
